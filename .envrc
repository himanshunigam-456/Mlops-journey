# direnv: loads on `cd` into this repo.
# Auto-activates uv venv and exposes service endpoints used by all 5 projects.

# Load secrets from infra/.env (gitignored). dotenv = direnv built-in.
dotenv infra/.env

# Service endpoints (match docker-compose.yml port mappings)
export MLFLOW_TRACKING_URI=http://localhost:5000
export MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
export OLLAMA_HOST=http://localhost:11434
export REDIS_URL=redis://localhost:6379/0

# Use the repo's uv-managed virtualenv if it exists
if [ -d ".venv" ]; then
  source .venv/bin/activate
fi
