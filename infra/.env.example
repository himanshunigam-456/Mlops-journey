# Copy to .env (gitignored) and fill in values for your local environment.
# These are read by docker-compose.yml AND .envrc (via direnv).
#
# In production, these come from your secret manager (AWS Secrets Manager,
# Vault, Doppler, etc.) — never from a committed file.

# Postgres (backs MLflow's metadata store)
POSTGRES_USER=mlops
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=mlflow

# MinIO (S3-compatible artifact storage)
MINIO_ROOT_USER=change-me-locally
MINIO_ROOT_PASSWORD=change-me-locally-min-8-chars

# AWS SDK env vars — point at local MinIO during dev,
# replaced with real AWS values when deploying to cloud.
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_DEFAULT_REGION=us-east-1
